components:
  schemas:
    APContact:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
        email:
          type: string
        isDefault:
          type: boolean
        organization:
          type: integer
          nullable: true
        customer:
          type: integer
      required:
      - customer
      - email
      - name
    APContactRequest:
      type: object
      properties:
        name:
          type: string
          minLength: 1
        email:
          type: string
          minLength: 1
        isDefault:
          type: boolean
        organization:
          type: integer
          nullable: true
        customer:
          type: integer
      required:
      - customer
      - email
      - name
    ActionEnum:
      enum:
      - LL
      - LU
      - HL
      - LD
      - EMPP
      - EMPD
      - HUBP
      - HUBD
      type: string
      description: |-
        * `LL` - LIVE LOAD
        * `LU` - LIVE UNLOAD
        * `HL` - HOOK LOADED
        * `LD` - DROP LOADED
        * `EMPP` - EMPTY PICKUP
        * `EMPD` - EMPTY DROP
        * `HUBP` - HUB PICKUP
        * `HUBD` - HUB DROPOFF
    Address:
      type: object
      description: Serializer for the Address model.
      properties:
        id:
          type: integer
          readOnly: true
        placeName:
          type: string
        street:
          type: string
          maxLength: 300
        city:
          type: string
          maxLength: 50
        state:
          type: string
          maxLength: 2
        zipCode:
          type: string
          maxLength: 12
        country:
          type: string
        latitude:
          type: string
          format: decimal
          pattern: ^-?\d{0,3}(?:\.\d{0,7})?$
          nullable: true
        longitude:
          type: string
          format: decimal
          pattern: ^-?\d{0,3}(?:\.\d{0,7})?$
          nullable: true
      required:
      - city
      - placeName
      - state
      - street
      - zipCode
    AddressRequest:
      type: object
      description: Serializer for the Address model.
      properties:
        placeName:
          type: string
          minLength: 1
        street:
          type: string
          minLength: 1
          maxLength: 300
        city:
          type: string
          minLength: 1
          maxLength: 50
        state:
          type: string
          minLength: 1
          maxLength: 2
        zipCode:
          type: string
          minLength: 1
          maxLength: 12
        country:
          type: string
          minLength: 1
        latitude:
          type: string
          format: decimal
          pattern: ^-?\d{0,3}(?:\.\d{0,7})?$
          nullable: true
        longitude:
          type: string
          format: decimal
          pattern: ^-?\d{0,3}(?:\.\d{0,7})?$
          nullable: true
      required:
      - city
      - placeName
      - state
      - street
      - zipCode
