      - deletedCount
      - deletedIds
    Stop:
      type: object
      properties:
        id:
          type: integer
        leg:
          type: integer
          readOnly: true
        address:
          type: integer
        stopNumber:
          type: integer
          maximum: 2147483647
          minimum: 0
          description: Order of this stop within the leg
        startRange:
          type: string
          format: date-time
          description: The earliest time the stop can occur
        endRange:
          type: string
          format: date-time
          nullable: true
          description: The latest time the stop can occur (optional)
        timestamp:
          type: string
          format: date-time
          description: When this stop was created
        action:
          allOf:
          - $ref: '#/components/schemas/ActionEnum'
          description: |-
            The type of action to be performed at this stop

            * `LL` - LIVE LOAD
            * `LU` - LIVE UNLOAD
            * `HL` - HOOK LOADED
            * `LD` - DROP LOADED
            * `EMPP` - EMPTY PICKUP
            * `EMPD` - EMPTY DROP
            * `HUBP` - HUB PICKUP
            * `HUBD` - HUB DROPOFF
        poNumbers:
          type: string
          description: Purchase order numbers associated with this stop
        driverNotes:
          type: string
          description: Notes for the driver regarding this stop
      required:
      - action
      - address
      - startRange
      - stopNumber
