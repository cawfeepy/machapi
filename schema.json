                description: Leg with nested stops and shipment assignments. Shipment
                  assignments assign a carrier and driver to the leg.
              UpdateLegRequest:
                value:
                  id: 1
                  stops:
                  - id: 1
                    stop_number: 1
                    address: 1
                    start_range: '2024-01-15T09:00:00Z'
                    action: LL
                  - id: 2
                    stop_number: 2
                    address: 3
                    action: LU
